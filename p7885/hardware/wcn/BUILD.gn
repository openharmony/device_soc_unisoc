ohos_prebuilt_etc("regulatory.db.p7s") {
  source = "$WCN_PATH/regulatory.db.p7s"
  install_enable = true
  install_images = [ chipset_base_dir ]
  subsystem_name = "${SUBSYSTEM_NAME}"
  part_name = "${PART_NAME}"
}
