	     audio:  bit16 adsp
	     chsys:  bit20 ch, bit21 ch cali
	     bit 31 clear -->
	<partion_item>
		<partition00 base="0x62800000" size="0x10000"  name="pmsys"    src_file="pm_sys"        dst_file="pmsys"    flag="0x00001001"/>
	</partion_item>
