# avc:  denied  { transfer } for  pid=858 comm="ui_service" scontext=u:r:ui_service:s0 tcontext=u:r:distributeddata:s0 tclass=binder permissive=0
allow ui_service distributeddata:binder { transfer };

# avc:  denied  { ioctl } for  pid=928 comm="OS_IPC_3_2188" path="/dev/access_token_id" dev="tmpfs" ino=361 ioctlcmd=0x5413 scontext=u:r:ui_service:s0 tcontext=u:object_r:dev_at_file:s0 tclass=chr_file permissive=1
