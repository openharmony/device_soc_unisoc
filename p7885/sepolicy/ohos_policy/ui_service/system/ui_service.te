allowxperm ui_service dev_at_file:chr_file ioctl { 0x5413 };

# avc:  denied  { transfer } for  pid=873 comm="OS_FFRT_2_0" scontext=u:r:ui_service:s0 tcontext=u:r:normal_hap:s0 tclass=binder permissive=1
