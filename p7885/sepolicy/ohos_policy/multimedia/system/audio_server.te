# avc:  denied  { read } for  pid=550 comm="sa_main" name="u:object_r:hiviewdfx_hiview_param:s0" dev="tmpfs" ino=131 scontext=u:r:audio_server:s0 tcontext=u:object_r:hiviewdfx_hiview_param:s0 tclass=file permissive=0
