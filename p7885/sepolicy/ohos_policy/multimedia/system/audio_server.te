typeattribute audio_server devinfo_type_allow_attr;

# avc:  denied  { ioctl } for  pid=469 comm="OS_IPC_3_689" path="/dev/access_token_id" dev="tmpfs" ino=358 ioctlcmd=0x5413 scontext=u:r:audio_server:s0 tcontext=u:object_r:dev_at_file:s0 tclass=chr_file permissive=1
allow audio_server dev_at_file:chr_file { ioctl };

# avc:  denied  { get } for service=1912 sid=u:r:audio_server:s0 scontext=u:r:audio_server:s0 tcontext=u:object_r:sa_concurrent_task_service:s0 tclass=samgr_class permissive=1
